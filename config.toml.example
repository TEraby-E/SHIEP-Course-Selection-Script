# Proxy Configuration
USE_PROXY = false  # Set to true to enable SOCKS5 proxy globally

[proxies]
all = "socks5://127.0.0.1:114514"

# ============================================================
# User Selection Configurations
# ============================================================

# -------------------- FirstUser= --------------------
[[USER_CONFIGS]]
label = "User_Alice"

  # Table 1
  [[USER_CONFIGS.tables]]
  profileId = "114514"
  course_ids = [
    "COURSEID_A1",
    "COURSEID_A2",
  ]

  # Table 2
  [[USER_CONFIGS.tables]]
  profileId = "1919810"
  course_ids = [
    "COURSEID_B1",
    "COURSEID_B2",
  ]


# -------------------- SecondUser --------------------
[[USER_CONFIGS]]
label = "User_Bob"

  [[USER_CONFIGS.tables]]
  profileId = "233"
  course_ids = [
    "COURSEID_C1",
    "COURSEID_C2",
  ]

